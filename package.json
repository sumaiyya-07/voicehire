{
    "name": "voicehire",
    "version": "1.0.0",
    "description": "VoiceHire AI Mock Interview Platform",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "start": "node voicehire-backend/server.js",
        "dev": "node voicehire-backend/server.js",
        "build": "cd voicehire-nextjs && npm run build",
        "install:backend": "cd voicehire-backend && npm install",
        "install:frontend": "cd voicehire-nextjs && npm install",
        "install:all": "cd voicehire-backend && npm install && cd ../voicehire-nextjs && npm install"
    },
    "dependencies": {
        "mongodb": "^7.1.0"
    }
}
